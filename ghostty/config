# WezTerm parity
#
# Ghostty cannot fully reproduce WezTerm workspaces, custom tab shapes, or
# WezTerm's copy-mode motions. The bindings below keep the same leader
# sequence where Ghostty has an equivalent action.

font-family = JetBrainsMono Nerd Font Mono
font-size = 15

background = #000000
foreground = #FFFFFF
background-opacity = 0.75
background-blur = 20
selection-background = #00ff00
selection-foreground = #FFFFFF

window-width = 160
window-height = 160
window-theme = dark
window-decoration = auto
window-new-tab-position = current
window-padding-x = 2
window-padding-y = 2
confirm-close-surface = true

macos-titlebar-style = tabs
macos-non-native-fullscreen = false
shell-integration-features = cursor,no-sudo,no-title,no-ssh-env,no-ssh-terminfo,path

# Match WezTerm's disable_default_key_bindings = true.
keybind = clear

# Clipboard
keybind = super+c=copy_to_clipboard:mixed
keybind = super+v=paste_from_clipboard
keybind = copy=copy_to_clipboard:mixed
keybind = paste=paste_from_clipboard

# Command palette and config reload
keybind = super+p=toggle_command_palette
keybind = ctrl+shift+p=toggle_command_palette
keybind = ctrl+shift+r=reload_config

# Tabs
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = super+t=new_tab
keybind = super+w=close_tab:this
keybind = ctrl+q>{=move_tab:-1
keybind = ctrl+q>}=move_tab:1

keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=last_tab

# Fullscreen
keybind = alt+enter=toggle_fullscreen

# WezTerm leader-style commands
keybind = ctrl+q>w=toggle_tab_overview
keybind = ctrl+q>$=prompt_tab_title
keybind = ctrl+q>shift+w=new_window
keybind = ctrl+q>[=start_search

# Splits
keybind = ctrl+q>d=new_split:down
keybind = ctrl+q>r=new_split:right
keybind = ctrl+q>x=close_surface
keybind = ctrl+q>h=goto_split:left
keybind = ctrl+q>l=goto_split:right
keybind = ctrl+q>k=goto_split:up
keybind = ctrl+q>j=goto_split:down
keybind = ctrl+shift+[=toggle_tab_overview
keybind = ctrl+q>z=toggle_split_zoom

# Font size
keybind = ctrl++=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Key tables
keybind = ctrl+q>s=activate_key_table:resize_split
keybind = resize_split/h=resize_split:left,1
keybind = resize_split/l=resize_split:right,1
keybind = resize_split/k=resize_split:up,1
keybind = resize_split/j=resize_split:down,1
keybind = resize_split/enter=deactivate_key_table
keybind = resize_split/escape=deactivate_key_table
keybind = resize_split/catch_all=ignore

keybind = ctrl+q>a=activate_key_table_once:activate_split
keybind = activate_split/h=goto_split:left
keybind = activate_split/l=goto_split:right
keybind = activate_split/k=goto_split:up
keybind = activate_split/j=goto_split:down
keybind = activate_split/catch_all=ignore
